const TABS = [
  { id: "overview", label: "Overview", Icon: Activity },
  { id: "log", label: "Log Trade", Icon: Plus },
  { id: "payouts", label: "Payouts", Icon: Wallet },
  { id: "analytics", label: "Analytics", Icon: BarChart3 },
];

export default function TradingTerminal() {
  const [accounts, setAccounts] = useState(initialAccounts);
  const [trades, setTrades] = useState(initialTrades);
  const [payouts] = useState(initialPayouts);
  const [trailMode, setTrailMode] = useState("eod");
  const [activeTab, setActiveTab] = useState("overview");
  const [now, setNow] = useState(nyNow());

  useEffect(() => {
    const id = setInterval(() => setNow(nyNow()), 1000);
    return () => clearInterval(id);
  }, []);

  const accountsById = useMemo(() => Object.fromEntries(accounts.map((a) => [a.id, a])), [accounts]);

  const metricsByAccount = useMemo(() => {
    const out = {};
    accounts.forEach((a) => { out[a.id] = computeAccountMetrics(a, trailMode); });
    return out;
  }, [accounts, trailMode]);

  const tradesByAccount = useMemo(() => aggregate(trades, (t) => t.accountId), [trades]);

  const accountRanking = useMemo(() => {
    return accounts
      .map((a) => ({
        id: a.id, name: a.name,
        winRate: winRateOf(tradesByAccount[a.id]),
        trades: tradesByAccount[a.id]?.total ?? 0,
      }))
      .sort((a, b) => (b.winRate ?? -1) - (a.winRate ?? -1));
  }, [accounts, tradesByAccount]);

  const topRankedId = accountRanking[0]?.trades > 0 ? accountRanking[0].id : null;

  const phase = sessionPhaseInfo(now);
  const timeStr = now.toLocaleTimeString("en-US", { hour12: false, hour: "2-digit", minute: "2-digit", second: "2-digit" });

  function handleLogTrade({ accountId, grade, phase, triggers, pnl, notes }) {
    setAccounts((prev) => prev.map((a) => {
      if (a.id !== accountId) return a;
      const newBalance = a.currentBalance + pnl;
      return {
        ...a,
        currentBalance: newBalance,
        currentEquity: newBalance,
        peakBalance: Math.max(a.peakBalance, newBalance),
        peakEquity: Math.max(a.peakEquity, newBalance),
      };
    }));
    setTrades((prev) => [
      ...prev,
      { id: prev.length ? Math.max(...prev.map((t) => t.id)) + 1 : 1, accountId, date: "Today", grade, phase, triggers, pnl, notes },
    ]);
  }

  function handleResetSession() {
    setAccounts((prev) => prev.map((a) => ({
      ...a,
      dailyStartBalance: a.currentBalance,
      currentEquity: a.currentBalance,
    })));
  }

  const totalEquity = accounts.reduce((s, a) => s + metricsByAccount[a.id].current, 0);
  const totalDailyPnl = accounts.reduce((s, a) => s + metricsByAccount[a.id].dailyPnL, 0);
  const activeCount = accounts.filter((a) => metricsByAccount[a.id].status === "active" || metricsByAccount[a.id].status === "target").length;

  return (
    <div className="font-display min-h-screen bg-zinc-950 text-zinc-100">
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap');
        .font-display { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .font-data { font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace; }
        .custom-scroll::-webkit-scrollbar { height: 6px; width: 6px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 9999px; }
        select { color-scheme: dark; }
      `}</style>

      {/* ---------- Header ---------- */}
      <div className="border-b border-zinc-800 bg-zinc-950/95 px-4 py-3 backdrop-blur sm:px-6">
        <div className="mx-auto flex max-w-[1400px] flex-wrap items-center justify-between gap-3">
          <div>
            <div className="flex items-center gap-2">
              <div className="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500">
                <Zap size={16} className="text-zinc-950" />
              </div>
              <div>
                <h1 className="text-sm font-bold leading-none text-zinc-50">HTF MEAN REVERSION · LTF CONTINUATION</h1>
                <span className="text-[11px] text-zinc-500">Multi-Account Prop Desk Terminal</span>
              </div>
            </div>
          </div>

          <div className="flex flex-wrap items-center gap-4">
            <div className="text-right">
              <div className="font-data text-sm font-semibold tabular-nums text-zinc-200">{timeStr} <span className="text-zinc-500">NY</span></div>
              <div className={cx("text-[11px] font-medium", phase.tone)}>{phase.label}</div>
            </div>

            <div className="flex items-center rounded-lg border border-zinc-800 bg-zinc-900 p-0.5 text-xs font-semibold">
              <button onClick={() => setTrailMode("realtime")}
                className={cx("rounded-md px-2.5 py-1.5 transition-colors", trailMode === "realtime" ? "bg-amber-500 text-zinc-950" : "text-zinc-400 hover:text-zinc-200")}>
                Real-Time Trail
              </button>
              <button onClick={() => setTrailMode("eod")}
                className={cx("rounded-md px-2.5 py-1.5 transition-colors", trailMode === "eod" ? "bg-amber-500 text-zinc-950" : "text-zinc-400 hover:text-zinc-200")}>
                EOD Trail
              </button>
            </div>

            <button onClick={handleResetSession}
              className="flex items-center gap-1.5 rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-1.5 text-xs font-semibold text-zinc-300 transition-colors hover:border-zinc-700 hover:text-zinc-100">
              <RefreshCw size={13} /> Start New Session
            </button>
          </div>
        </div>
      </div>

      {/* ---------- Persistent Risk Strip ---------- */}
      <div className="border-b border-zinc-800 bg-zinc-950 px-4 py-3 sm:px-6">
        <div className="mx-auto max-w-[1400px]">
          <div className="mb-2 flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-wider text-zinc-500">
            <ShieldAlert size={12} /> Drawdown Buffer — All Accounts
          </div>
          <div className="custom-scroll flex gap-3 overflow-x-auto pb-1">
            {accounts.map((a) => (
              <RiskStripItem key={a.id} acc={a} metrics={metricsByAccount[a.id]} />
            ))}
          </div>
        </div>
      </div>

      {/* ---------- Tabs ---------- */}
      <div className="border-b border-zinc-800 px-4 sm:px-6">
        <div className="mx-auto flex max-w-[1400px] gap-1">
          {TABS.map((t) => {
            const Icon = t.Icon;
            const activeCls = activeTab === t.id ? "border-amber-500 text-amber-400" : "border-transparent text-zinc-500 hover:text-zinc-300";
            return (
              <button key={t.id} onClick={() => setActiveTab(t.id)}
                className={cx("flex items-center gap-1.5 border-b-2 px-3 py-3 text-sm font-semibold transition-colors", activeCls)}>
                <Icon size={14} /> {t.label}
              </button>
            );
          })}
        </div>
      </div>

      {/* ---------- Content ---------- */}
      <div className="mx-auto max-w-[1400px] px-4 py-6 sm:px-6">
        {activeTab === "overview" && (
          <div className="flex flex-col gap-6">
            <div className="grid grid-cols-2 gap-4 md:grid-cols-4">
              <StatCard label="Total Equity" value={fmtMoney(totalEquity)} Icon={DollarSign} />
              <StatCard label="Today's PnL" value={fmtMoney(totalDailyPnl, { showSign: true })} Icon={Activity}
                tone={totalDailyPnl >= 0 ? "text-emerald-400" : "text-rose-400"} />
              <StatCard label="Accounts Tradeable" value={`${activeCount} / ${accounts.length}`} Icon={ShieldCheck} />
              <StatCard label="Trail Mode" value={trailMode === "realtime" ? "Real-Time" : "EOD"} Icon={Lock} />
            </div>
            <div className="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
              {accounts.map((a) => (
                <AccountCard
                  key={a.id}
                  acc={a}
                  metrics={metricsByAccount[a.id]}
                  winRate={winRateOf(tradesByAccount[a.id])}
                  tradeCount={tradesByAccount[a.id]?.total ?? 0}
                  isTopRanked={a.id === topRankedId}
                />
              ))}
            </div>
          </div>
        )}

        {activeTab === "log" && (
          <div className="grid grid-cols-1 gap-6 lg:grid-cols-5">
            <div className="lg:col-span-2">
              <LogTradeForm accounts={accounts} metricsByAccount={metricsByAccount} onSubmit={handleLogTrade} />
            </div>
            <div className="lg:col-span-3">
              <TradeTable trades={trades} accountsById={accountsById} />
            </div>
          </div>
        )}

        {activeTab === "payouts" && (
          <PayoutsPanel payouts={payouts} accountsById={accountsById} accountRanking={accountRanking} />
        )}

        {activeTab === "analytics" && (
          <AnalyticsPanel trades={trades} />
        )}
      </div>
    </div>
  );
}
