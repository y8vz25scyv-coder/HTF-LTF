/* =========================================================================
   ANALYTICS PANEL
   ========================================================================= */

function HeatCell({ bucket }) {
  const wr = winRateOf(bucket);
  if (wr === null) {
    return <td className="border border-zinc-800 px-3 py-3 text-center text-xs text-zinc-600">—</td>;
  }
  const bg = wr >= 65 ? "bg-emerald-900/60" : wr >= 45 ? "bg-yellow-900/40" : "bg-rose-900/40";
  const text = wr >= 65 ? "text-emerald-300" : wr >= 45 ? "text-yellow-300" : "text-rose-300";
  return (
    <td className={cx("border border-zinc-800 px-3 py-3 text-center", bg)}>
      <div className={cx("font-data text-base font-bold tabular-nums", text)}>{fmtPct(wr, 0)}</div>
      <div className="text-[10px] text-zinc-500">{bucket.wins}W / {bucket.total - bucket.wins}L</div>
    </td>
  );
}

const CHART_COLORS = { good: "#34d399", mid: "#facc15", bad: "#fb7185" };
function barColor(wr) {
  if (wr >= 65) return CHART_COLORS.good;
  if (wr >= 45) return CHART_COLORS.mid;
  return CHART_COLORS.bad;
}

function AnalyticsPanel({ trades }) {
  const byGrade = aggregate(trades, (t) => t.grade);
  const byPhase = aggregate(trades, (t) => t.phase);
  const byMatrix = aggregate(trades, (t) => `${t.grade}|${t.phase}`);

  const totalTrades = trades.length;
  const totalWins = trades.filter((t) => t.pnl > 0).length;
  const overallWR = totalTrades ? (totalWins / totalTrades) * 100 : null;
  const netPnl = trades.reduce((s, t) => s + t.pnl, 0);

  const gradeChart = GRADES.map((g) => ({
    name: g, winRate: winRateOf(byGrade[g]) ?? 0, count: byGrade[g]?.total ?? 0,
  }));
  const phaseChart = PHASES.map((p) => ({
    name: p.short, winRate: winRateOf(byPhase[p.id]) ?? 0, count: byPhase[p.id]?.total ?? 0,
  }));

  const p1wr = winRateOf(byPhase["phase1"]);
  const p2wr = winRateOf(byPhase["phase2"]);
  const edge = p1wr !== null && p2wr !== null ? p2wr - p1wr : null;

  const tooltipStyle = { background: "#18181b", border: "1px solid #3f3f46", borderRadius: 8, fontSize: 12, color: "#e4e4e7" };

  return (
    <div className="flex flex-col gap-6">
      <div className="grid grid-cols-2 gap-4 md:grid-cols-4">
        <StatCard label="Total Trades" value={totalTrades} Icon={Activity} />
        <StatCard label="Overall Win Rate" value={fmtPct(overallWR, 0)} Icon={Target} tone="text-amber-400" />
        <StatCard label="Net PnL" value={fmtMoney(netPnl, { showSign: true })} Icon={DollarSign}
          tone={netPnl >= 0 ? "text-emerald-400" : "text-rose-400"} />
        <StatCard label="Best Grade" value="A+" sub={`${fmtPct(winRateOf(byGrade["A+"]), 0)} win rate`} Icon={Award} tone="text-amber-400" />
      </div>

      {edge !== null && (
        <div className="flex items-start gap-3 rounded-xl border border-emerald-900 bg-emerald-950/20 px-5 py-4">
          <Zap size={18} className="mt-0.5 shrink-0 text-emerald-400" />
          <p className="text-sm text-zinc-300">
            Phase 2 (mean reversion) trades are winning at{" "}
            <span className="font-data font-semibold text-emerald-400">{fmtPct(p2wr, 0)}</span> vs{" "}
            <span className="font-data font-semibold text-rose-400">{fmtPct(p1wr, 0)}</span> for Phase 1 (continuation) —
            a <span className="font-data font-semibold text-emerald-400">{edge >= 0 ? "+" : ""}{edge.toFixed(0)}pt</span> edge
            that supports the fair-price reversion thesis in this sample.
          </p>
        </div>
      )}

      <div className="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
        <h3 className="mb-4 text-sm font-semibold text-zinc-200">Win Rate — Setup Grade × NY Session Phase</h3>
        <div className="overflow-x-auto">
          <table className="w-full border-collapse text-sm">
            <thead>
              <tr>
                <th className="border border-zinc-800 bg-zinc-950 px-3 py-2 text-left text-[11px] uppercase tracking-wider text-zinc-500">Grade</th>
                <th className="border border-zinc-800 bg-zinc-950 px-3 py-2 text-[11px] uppercase tracking-wider text-zinc-500">Phase 1</th>
                <th className="border border-zinc-800 bg-zinc-950 px-3 py-2 text-[11px] uppercase tracking-wider text-zinc-500">Phase 2</th>
              </tr>
            </thead>
            <tbody>
              {GRADES.map((g) => (
                <tr key={g}>
                  <td className="border border-zinc-800 bg-zinc-950 px-3 py-3"><GradeBadge grade={g} /></td>
                  <HeatCell bucket={byMatrix[`${g}|phase1`]} />
                  <HeatCell bucket={byMatrix[`${g}|phase2`]} />
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div className="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <div className="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
          <h3 className="mb-4 text-sm font-semibold text-zinc-200">Win Rate by Setup Grade</h3>
          <ResponsiveContainer width="100%" height={220}>
            <BarChart data={gradeChart} margin={{ top: 4, right: 8, left: -16, bottom: 0 }}>
              <CartesianGrid stroke="#27272a" vertical={false} />
              <XAxis dataKey="name" stroke="#71717a" fontSize={12} tickLine={false} axisLine={false} />
              <YAxis stroke="#71717a" fontSize={12} tickLine={false} axisLine={false} domain={[0, 100]} />
              <Tooltip contentStyle={tooltipStyle} formatter={(v) => [`${v.toFixed(0)}%`, "Win Rate"]} cursor={{ fill: "#27272a" }} />
              <Bar dataKey="winRate" radius={[4, 4, 0, 0]}>
                {gradeChart.map((d, i) => <Cell key={i} fill={barColor(d.winRate)} />)}
              </Bar>
            </BarChart>
          </ResponsiveContainer>
        </div>

        <div className="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
          <h3 className="mb-4 text-sm font-semibold text-zinc-200">Win Rate by NY Session Phase</h3>
          <ResponsiveContainer width="100%" height={220}>
            <BarChart data={phaseChart} margin={{ top: 4, right: 8, left: -16, bottom: 0 }}>
              <CartesianGrid stroke="#27272a" vertical={false} />
              <XAxis dataKey="name" stroke="#71717a" fontSize={12} tickLine={false} axisLine={false} />
              <YAxis stroke="#71717a" fontSize={12} tickLine={false} axisLine={false} domain={[0, 100]} />
              <Tooltip contentStyle={tooltipStyle} formatter={(v) => [`${v.toFixed(0)}%`, "Win Rate"]} cursor={{ fill: "#27272a" }} />
              <Bar dataKey="winRate" radius={[4, 4, 0, 0]}>
                {phaseChart.map((d, i) => <Cell key={i} fill={barColor(d.winRate)} />)}
              </Bar>
            </BarChart>
          </ResponsiveContainer>
        </div>
      </div>
    </div>
  );
}

