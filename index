function nyNow() {
  const now = new Date();
  const nyString = now.toLocaleString("en-US", { timeZone: "America/New_York" });
  return new Date(nyString);
}

function sessionPhaseInfo(ny) {
  const open = new Date(ny);
  open.setHours(9, 30, 0, 0);
  const diffMin = (ny - open) / 60000;
  if (diffMin < 0) return { label: "Pre-Market", tone: "text-zinc-500" };
  if (diffMin <= 10) return { label: `Phase 1 Window · ${Math.floor(diffMin)}m since open`, tone: "text-amber-400" };
  if (diffMin <= 90) return { label: `Phase 2 Window · ${Math.floor(diffMin)}m since open`, tone: "text-emerald-400" };
  return { label: "Outside Strategy Window", tone: "text-zinc-500" };
}

