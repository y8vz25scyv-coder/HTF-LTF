/* =========================================================================
   LOG TRADE FORM
   ========================================================================= */

function LogTradeForm({ accounts, metricsByAccount, onSubmit }) {
  const [accountId, setAccountId] = useState(accounts[0].id);
  const [grade, setGrade] = useState("A");
  const [phase, setPhase] = useState("phase2");
  const [triggers, setTriggers] = useState([]);
  const [pnl, setPnl] = useState("");
  const [notes, setNotes] = useState("");

  const selectedMetrics = metricsByAccount[accountId];
  const blocked = selectedMetrics && (selectedMetrics.status === "locked" || selectedMetrics.status === "failed");

  const pnlValid = pnl !== "" && !Number.isNaN(parseFloat(pnl));
  const canSubmit = accountId && grade && phase && triggers.length > 0 && pnlValid && !blocked;

  function toggleTrigger(t) {
    setTriggers((prev) => (prev.includes(t) ? prev.filter((x) => x !== t) : [...prev, t]));
  }

  function handleSubmit(e) {
    e.preventDefault();
    if (!canSubmit) return;
    onSubmit({ accountId, grade, phase, triggers, pnl: parseFloat(pnl), notes });
    setPnl("");
    setNotes("");
    setTriggers([]);
  }

  const inputCls = "w-full rounded-lg border border-zinc-800 bg-zinc-950 px-3 py-2 text-sm text-zinc-100 outline-none transition-colors focus:border-amber-600 focus:ring-1 focus:ring-amber-600";
  const labelCls = "mb-1.5 block text-xs font-semibold uppercase tracking-wider text-zinc-500";

  return (
    <form onSubmit={handleSubmit} className="flex flex-col gap-4 rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <h3 className="flex items-center gap-2 font-semibold text-zinc-100">
        <Plus size={16} className="text-amber-400" /> Log Trade
      </h3>

      <div>
        <label className={labelCls}>Account</label>
        <select className={inputCls} value={accountId} onChange={(e) => setAccountId(e.target.value)}>
          {accounts.map((a) => {
            const m = metricsByAccount[a.id];
            const disabled = m.status === "locked" || m.status === "failed";
            return (
              <option key={a.id} value={a.id}>
                {a.name} — {a.tier} {a.size}{disabled ? ` (${STATUS_META[m.status].label})` : ""}
              </option>
            );
          })}
        </select>
      </div>

      {blocked && (
        <div className="flex items-start gap-2 rounded-lg border border-rose-900 bg-rose-950/30 px-3 py-2 text-xs text-rose-300">
          <AlertTriangle size={14} className="mt-0.5 shrink-0" />
          <span>
            {selectedMetrics.status === "failed"
              ? "This account has breached its trailing drawdown and is disabled. No further trades can be logged."
              : "This account hit its Daily Loss Limit and is locked for the session. Trading is disabled until the next session resets."}
          </span>
        </div>
      )}

      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className={labelCls}>Setup Grade</label>
          <select className={inputCls} value={grade} onChange={(e) => setGrade(e.target.value)}>
            {GRADES.map((g) => <option key={g} value={g}>{g}</option>)}
          </select>
        </div>
        <div>
          <label className={labelCls}>PnL ($)</label>
          <input
            className={cx(inputCls, "font-data tabular-nums")}
            type="number" step="1" placeholder="e.g. 340 or -180"
            value={pnl} onChange={(e) => setPnl(e.target.value)}
          />
        </div>
      </div>

      <div>
        <label className={labelCls}>NY Open Phase</label>
        <select className={inputCls} value={phase} onChange={(e) => setPhase(e.target.value)}>
          {PHASES.map((p) => <option key={p.id} value={p.id}>{p.label}</option>)}
        </select>
      </div>

      <div>
        <label className={labelCls}>Execution Trigger</label>
        <div className="flex flex-wrap gap-3">
          {TRIGGERS.map((t) => (
            <label key={t} className="flex cursor-pointer items-center gap-2 rounded-lg border border-zinc-800 bg-zinc-950 px-3 py-2 text-sm text-zinc-300 hover:border-zinc-700">
              <input type="checkbox" checked={triggers.includes(t)} onChange={() => toggleTrigger(t)}
                className="h-3.5 w-3.5 accent-amber-500" />
              {t}
            </label>
          ))}
        </div>
      </div>

      <div>
        <label className={labelCls}>Notes (optional)</label>
        <textarea className={inputCls} rows={2} placeholder="Context on the read, confluence, HTF level..."
          value={notes} onChange={(e) => setNotes(e.target.value)} />
      </div>

      <button type="submit" disabled={!canSubmit}
        className={cx("mt-1 rounded-lg px-4 py-2.5 text-sm font-semibold transition-colors",
          canSubmit ? "bg-amber-500 text-zinc-950 hover:bg-amber-400" : "cursor-not-allowed bg-zinc-800 text-zinc-500")}>
        Log Trade
      </button>
    </form>
  );
}

