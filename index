function cx(...c) { return c.filter(Boolean).join(" "); }

function fmtMoney(n, opts = {}) {
  const { showSign = false } = opts;
  const abs = Math.abs(n);
  const s = abs.toLocaleString("en-US", { maximumFractionDigits: 0 });
  const sign = n < 0 ? "-" : showSign && n > 0 ? "+" : "";
  return `${sign}$${s}`;
}

function fmtPct(n, d = 1) {
  if (n === null || n === undefined || Number.isNaN(n)) return "—";
  return `${n.toFixed(d)}%`;
}

function getRef(acc, trailMode) {
  return trailMode === "realtime"
    ? { current: acc.currentEquity, peak: acc.peakEquity }
    : { current: acc.currentBalance, peak: acc.peakBalance };
}

function computeAccountMetrics(acc, trailMode) {
  const { current, peak } = getRef(acc, trailMode);

  const dailyLossSoFar = Math.max(0, acc.dailyStartBalance - current);
  const dailyLocked = dailyLossSoFar >= acc.dllThreshold;
  const dllBuffer = Math.max(0, acc.dllThreshold - dailyLossSoFar);

  const rawTrail = peak - acc.trailDistance;
  const trailLocked = rawTrail >= acc.startingBalance;
  const trailingLine = trailLocked ? acc.startingBalance : rawTrail;
  const trailingBuffer = Math.max(0, current - trailingLine);
  const breached = current <= trailingLine;

  const targetBalance = acc.startingBalance + acc.targetProfit;
  const progressToTarget = Math.min(
    100,
    Math.max(0, ((current - acc.startingBalance) / acc.targetProfit) * 100)
  );

  let status = "active";
  if (breached) status = "failed";
  else if (dailyLocked) status = "locked";
  else if (current >= targetBalance) status = "target";

  const worstCaseBuffer = status === "failed" ? 0 : Math.min(dllBuffer, trailingBuffer);
  const dailyPnL = current - acc.dailyStartBalance;

  return {
    current, peak, dailyLossSoFar, dailyLocked, dllBuffer, trailingLine, trailLocked,
    trailingBuffer, breached, targetBalance, progressToTarget, status, worstCaseBuffer, dailyPnL,
  };
}

function aggregate(trades, keyFn) {
  const map = {};
  trades.forEach((t) => {
    const k = keyFn(t);
    if (!map[k]) map[k] = { wins: 0, total: 0, pnl: 0 };
    map[k].total += 1;
    if (t.pnl > 0) map[k].wins += 1;
    map[k].pnl += t.pnl;
  });
  return map;
}

function winRateOf(bucket) {
  if (!bucket || bucket.total === 0) return null;
  return (bucket.wins / bucket.total) * 100;
}

